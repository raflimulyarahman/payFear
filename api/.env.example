# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/payfear?schema=public

# Auth
JWT_SECRET=change_this_to_a_random_string_minimum_32_characters
JWT_EXPIRES_IN=7d

# SIWE
SIWE_DOMAIN=localhost

# Blockchain (Base Sepolia)
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
ESCROW_CONTRACT_ADDRESS=0x6B5075137c32C39CB0c0385A23101260188e404d
RELAYER_PRIVATE_KEY=0x_your_relayer_wallet_private_key

# Optional — Email (Resend)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=noreply@yourdomain.com

# Optional — Redis (falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# Optional — File Storage (S3-compatible)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=payfear-uploads
