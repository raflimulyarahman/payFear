// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  REQUESTER
  EXECUTOR
  ADMIN
}

enum TaskStatus {
  DRAFT
  OPEN
  ACCEPTED
  IN_PROGRESS
  PROOF_SUBMITTED
  UNDER_REVIEW
  COMPLETED
  DISPUTED
  CANCELLED
  REFUNDED
  BLOCKED
}

enum TaskCategory {
  PHONE_CALLS
  SOCIAL
  RETURN_REFUND
  NEGOTIATION
  ADMIN_TASK
  OTHER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProofType {
  SCREENSHOT
  PHOTO
  TEXT
  VIDEO
}

enum EscrowStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REQUESTER
  RESOLVED_EXECUTOR
  ESCALATED
}

enum FlagReason {
  ILLEGAL_ACTIVITY
  HARASSMENT
  IMPERSONATION
  FRAUD
  PRIVACY_VIOLATION
  COERCION
  STALKING
  SOCIAL_ENGINEERING
  OTHER
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_WALLET_LINKED
  TASK_CREATED
  TASK_UPDATED
  TASK_ACCEPTED
  TASK_STARTED
  TASK_PROOF_SUBMITTED
  TASK_APPROVED
  TASK_DISPUTED
  TASK_CANCELLED
  TASK_REFUNDED
  TASK_BLOCKED
  ESCROW_CREATED
  ESCROW_RELEASED
  ESCROW_REFUNDED
  FLAG_CREATED
  FLAG_RESOLVED
  REVIEW_CREATED
  ADMIN_ACTION
}

// ============================================================
// MODELS
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  passwordHash    String?
  name            String
  avatarUrl       String?
  role            UserRole  @default(REQUESTER)
  bio             String?

  // Wallet / Base integration
  walletAddress   String?   @unique
  walletLinkedAt  DateTime?

  // Reputation
  rating          Float     @default(0)
  ratingCount     Int       @default(0)
  tasksCreated    Int       @default(0)
  tasksCompleted  Int       @default(0)
  totalSpent      Float     @default(0)
  totalEarned     Float     @default(0)
  trustScore      Float     @default(50)

  // Account state
  isVerified      Boolean   @default(false)
  isBanned        Boolean   @default(false)
  bannedReason    String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastLoginAt     DateTime?

  // Relations
  createdTasks    Task[]         @relation("RequesterTasks")
  executedTasks   Task[]         @relation("ExecutorTasks")
  proofs          TaskProof[]
  reviewsGiven    TaskReview[]   @relation("ReviewerReviews")
  reviewsReceived TaskReview[]   @relation("ReviewedReviews")
  disputesFiled   TaskDispute[]  @relation("DisputeFiler")
  flags           ModerationFlag[]
  auditLogs       AuditLog[]     @relation("AuditActor")

  @@index([email])
  @@index([walletAddress])
  @@index([role])
  @@map("users")
}

model Task {
  id                  String       @id @default(cuid())
  title               String
  description         String
  category            TaskCategory
  location            String
  address             String?

  // Financial
  budget              Float
  platformFee         Float        @default(0)
  urgencyFee          Float        @default(0)
  totalCost           Float
  currency            String       @default("USD")

  // Task details
  deadline            DateTime
  urgency             String       @default("normal")
  proofType           ProofType
  specialInstructions String?

  // Safety
  riskLevel           RiskLevel    @default(LOW)
  riskFlags           String[]     @default([])

  // State
  status              TaskStatus   @default(DRAFT)
  statusHistory       Json         @default("[]")

  // Relations
  requesterId         String
  requester           User         @relation("RequesterTasks", fields: [requesterId], references: [id])
  executorId          String?
  executor            User?        @relation("ExecutorTasks", fields: [executorId], references: [id])

  // Timestamps
  publishedAt         DateTime?
  acceptedAt          DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Child relations
  proofs              TaskProof[]
  payment             TaskPayment?
  reviews             TaskReview[]
  disputes            TaskDispute[]
  flags               ModerationFlag[]

  @@index([status])
  @@index([requesterId])
  @@index([executorId])
  @@index([category])
  @@index([riskLevel])
  @@index([createdAt])
  @@map("tasks")
}

model TaskProof {
  id            String    @id @default(cuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submittedById String
  submittedBy   User      @relation(fields: [submittedById], references: [id])

  proofType     ProofType
  textContent   String?
  fileUrl       String?
  fileName      String?
  fileSize      Int?
  mimeType      String?

  notes         String?

  createdAt     DateTime  @default(now())

  @@index([taskId])
  @@map("task_proofs")
}

model TaskPayment {
  id              String       @id @default(cuid())
  taskId          String       @unique
  task            Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  amount          Float
  platformFee     Float
  urgencyFee      Float        @default(0)
  totalAmount     Float
  currency        String       @default("USD")

  // Escrow state
  escrowStatus    EscrowStatus @default(PENDING)

  // Onchain references
  onchainTxHash   String?
  onchainTaskId   String?
  releaseTxHash   String?
  refundTxHash    String?

  fundedAt        DateTime?
  releasedAt      DateTime?
  refundedAt      DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([escrowStatus])
  @@map("task_payments")
}

model TaskReview {
  id            String   @id @default(cuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  reviewerId    String
  reviewer      User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  reviewedId    String
  reviewed      User     @relation("ReviewedReviews", fields: [reviewedId], references: [id])

  rating        Int
  comment       String?

  createdAt     DateTime @default(now())

  @@unique([taskId, reviewerId])
  @@index([reviewedId])
  @@map("task_reviews")
}

model TaskDispute {
  id            String        @id @default(cuid())
  taskId        String
  task          Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  filerId       String
  filer         User          @relation("DisputeFiler", fields: [filerId], references: [id])

  reason        String
  evidence      String?

  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedById  String?
  resolvedAt    DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([taskId])
  @@index([status])
  @@map("task_disputes")
}

model ModerationFlag {
  id            String     @id @default(cuid())

  taskId        String?
  task          Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  flaggedUserId String?
  flaggedUser   User?      @relation(fields: [flaggedUserId], references: [id])

  reporterId    String
  reason        FlagReason
  details       String?

  isResolved    Boolean    @default(false)
  resolvedById  String?
  resolvedAt    DateTime?
  resolution    String?

  createdAt     DateTime   @default(now())

  @@index([taskId])
  @@index([isResolved])
  @@map("moderation_flags")
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  actorId     String?
  actor       User?       @relation("AuditActor", fields: [actorId], references: [id])

  entityType  String
  entityId    String

  metadata    Json?
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime    @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model WalletConnection {
  id            String   @id @default(cuid())
  userId        String
  walletAddress String
  chainId       Int
  provider      String   @default("base")

  isActive      Boolean  @default(true)
  connectedAt   DateTime @default(now())

  @@unique([userId, walletAddress])
  @@index([walletAddress])
  @@map("wallet_connections")
}
